      "url": "/sermon-assistant?source=shortcut",
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192" }]
    },
    {
      "name": "Give",
      "short_name": "Give",
      "description": "Support JCTM ministry",
      "url": "/give?source=shortcut",
      "icons": [{ "src": "/icon-192.png", "sizes": "192x192" }]
    }
  ],
  "screenshots": [

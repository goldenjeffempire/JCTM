modules = ["nodejs-20", "web", "bash", "python-3.11", "postgresql-16"]

  [[artifacts]]
  id = "artifacts/jctm-platform"

  [[artifacts]]
  id = "artifacts/api-server"

  [[artifacts]]
  id = "artifacts/mockup-sandbox"

  [deployment]
  router = "application"
deploymentTarget = "vm"
run = ["bash", "-c", "PORT=5000 node artifacts/api-server/dist/index.mjs"]
build = ["bash", "-c", "pnpm install --frozen-lockfile && pnpm --filter @workspace/jctm-platform run build && pnpm --filter @workspace/api-server run build"]

  [deployment.postBuild]
  args = ["pnpm", "store", "prune"]
  env = { "CI" = "true" }

  [workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm install && pnpm --filter @workspace/jctm-platform run build && pnpm --filter @workspace/api-server run build && PORT=5000 node artifacts/api-server/dist/index.mjs"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

  [agent]
stack = "BEST_EFFORT_FALLBACK"
expertMode = true
integrations = ["javascript_object_storage:2.0.0"]

  [postMerge]
  path = "scripts/post-merge.sh"
timeoutMs = 180000

  [nix]
channel = "stable-25_05"

